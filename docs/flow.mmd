%% ClauseLens analysis pipeline — editable source. The committed flow.png/.pdf are
%% generated by scripts/make_diagrams.py (deterministic, no browser needed).
%% Render with: npx -y @mermaid-js/mermaid-cli -i flow.mmd -o flow.png
flowchart TB
  subgraph S1["Stage 1 — ingest (Haiku · Titan)"]
    direction LR
    P[parse<br/>PyMuPDF: text+page+bbox] --> C[chunk<br/>clause-aware] --> E[embed → FAISS] --> EN[entities] --> SU[summaries<br/>per-doc + master]
  end

  subgraph S2["Stage 2 — analysis (Sonnet)"]
    direction LR
    ES[extract structured<br/>deliverables · owners · budgets] --> BG[build graph<br/>node/edge JSON, D12] --> DF[detect findings<br/>risks · conflicts · gaps · deps] --> J[judge<br/>independent verify, D11]
  end

  SU --> ES

  LOOP["self-reflective RAG loop (D10)<br/>retrieve → grade relevance → (re-retrieve)<br/>generate → grade groundedness → (regenerate)"]
  ES -. reflective .-> LOOP
  DF -. reflective .-> LOOP

  ASSURE["Every finding: grounded → self-checked → independently verified<br/>cited to source clause · reflective loop · separate AI judge (correctness + bias)"]
  J --> ASSURE
