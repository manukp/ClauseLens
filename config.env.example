# Copy this file to `config.env` at the repo root and fill in your values.
# Real environment variables override these. NEVER commit config.env — it embeds
# your AWS account id / bucket name (config.env is gitignored).
#
# The model ids below are the verified demo defaults (see .claude/CLAUDE.md);
# you normally only need to set AWS_PROFILE and S3_BUCKET.

AWS_REGION=us-east-1
AWS_PROFILE=your-aws-profile
S3_BUCKET=your-bucket-name

# Bedrock model ids (high-volume / reasoning / embeddings tiers).
CHAT_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
REASONING_MODEL_ID=us.anthropic.claude-sonnet-4-6
EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
